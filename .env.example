# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# MySQL (obrigatório para rodar a aplicação)
# No Docker Compose, MYSQL_HOST é sobrescrito para "mysql" (nome do serviço).
#--------------------------------------------------------------------
DB_CONNECTION=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB_NAME=multi_gateway
# Para Docker: senha do root (usada pelo serviço mysql no compose)
MYSQL_ROOT_PASSWORD=secret


#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000